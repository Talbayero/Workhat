NEXT_PUBLIC_APP_NAME=Work Hat CRM
NEXT_PUBLIC_APP_URL=https://work-hat.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Use Supabase Secret key (sb_secret_...) or legacy service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=

# Work Hat Email Connector
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use `openssl rand -base64 32` or any high-entropy 32+ character secret.
EMAIL_TOKEN_ENCRYPTION_KEY=
# Pub/Sub topic format: projects/{project-id}/topics/{topic-name}
GOOGLE_PUBSUB_TOPIC=
# Optional shared secret appended to the Pub/Sub push endpoint as ?token=...
GMAIL_PUSH_TOKEN=
# Used by Vercel Cron Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Email provider
POSTMARK_SERVER_TOKEN=
POSTMARK_INBOUND_TOKEN=
RESEND_API_KEY=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# Security gateway
SECURITY_IP_BLACKLIST=
SECURITY_DYNAMIC_BLACKLIST_TTL_MS=
TURNSTILE_SECRET_KEY=
